rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isGerente() {
      return isSignedIn() && getUserData().role == 'gerente';
    }

    // Validation for Public Reservation
    function isValidReservationUpdate() {
        let currentStatus = resource.data.estado;
        let isAvailable = currentStatus == 'En Stock (Disponible para Venta)' || currentStatus == 'Apartado';
        return isAvailable;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Phones collection
    match /phones/{phoneId} {
      // Allow public read of Stock/Apartado (so they can see what is reserved)
      allow read: if isSignedIn() || 
                  resource.data.estado == 'En Stock (Disponible para Venta)' || 
                  resource.data.estado == 'Apartado';
      
      // Allow public update for Reservation Logic (unauthenticated can only update reservation + updatedAt)
      allow update: if (isAdmin() || isGerente()) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reservation', 'updatedAt']) && isValidReservationUpdate());
                    
      allow create: if isAdmin() || isGerente();
      allow delete: if isAdmin();
    }
    
    // Batches collection
    match /batches/{batchId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
    
    // Clients collection
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isGerente();
      allow delete: if isAdmin();
      
      // Sub-collections
      match /purchases/{purchaseId} {
        allow read: if isSignedIn();
        allow create: if isAdmin() || isGerente();
        allow update, delete: if isAdmin();
      }
      
      match /creditAdjustments/{adjId} {
        allow read: if isSignedIn();
        allow create: if isAdmin();
        allow update, delete: if false;
      }
      
      match /debtAdjustments/{adjId} {
        allow read: if isSignedIn();
        allow create: if isAdmin() || isGerente();
        allow update, delete: if false;
      }
    }
    
    // Accessories collection
    match /accessories/{accessoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGerente();
    }

    // Device Definitions (Smart Learner)
    match /device_definitions/{tac} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGerente();
    }
    
    // Price Catalog (Brain 2.0)
    match /price_catalog/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow all staff to contribute to the brain
    }
    
    // Pending Orders collection
    match /pendingOrders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (isAdmin() || isGerente() || resource.data.sessionId == request.auth.uid);
      allow update: if isAdmin() || isGerente();
      allow delete: if false;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
