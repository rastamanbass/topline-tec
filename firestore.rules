rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ── Helper functions ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isGerente() {
      return isSignedIn() && getUserData().role == 'gerente';
    }

    function isAdminOrGerente() {
      return isSignedIn() && getUserData().role in ['admin', 'gerente'];
    }

    function isTaller() {
      return isSignedIn() && getUserData().role == 'taller';
    }

    // Validation for Public Reservation
    // Checks that BOTH the current and new estado are within the allowed states
    // to prevent using the reservation path to set phones to Sold/Workshop/etc.
    function isValidReservationUpdate() {
        let currentStatus = resource.data.estado;
        let newStatus = request.resource.data.estado;
        let validStatuses = ['En Stock (Disponible para Venta)', 'Apartado'];
        return currentStatus in validStatuses && newStatus in validStatuses;
    }

    // ── Phone data validation helpers (added 2026-04-24) ──────────────────────
    // Block "Desconocida/Desconocido" fallback from being introduced as marca/modelo
    // Existing phones with these values can still be updated (legacy tolerance)
    function isBadFallback(v) {
      return v == 'Desconocida' || v == 'Desconocido' || v == 'desconocida' || v == 'desconocido';
    }

    // For CREATE: strict rules on new phones
    function hasValidPhoneCreate(d) {
      return d.marca is string && d.marca.size() > 0 && !isBadFallback(d.marca)
          && d.modelo is string && d.modelo.size() > 0 && !isBadFallback(d.modelo)
          && d.imei is string && d.imei.size() >= 4
          && (!('precioVenta' in d) || d.precioVenta == null || d.precioVenta is number)
          && (!('costo' in d) || d.costo == null || d.costo is number);
    }

    // For UPDATE: block "Desconocida" from being introduced as a CHANGE
    // If marca wasn't changed, legacy "Desconocida" values are tolerated
    function marcaChangeIsSafe() {
      return !('marca' in request.resource.data.diff(resource.data).affectedKeys())
          || !isBadFallback(request.resource.data.marca);
    }

    // Block precioVenta being set as string (keep it number or null)
    function precioTypeIsSafe() {
      return !('precioVenta' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.precioVenta == null
          || request.resource.data.precioVenta is number;
    }

    // Block modelo being changed to "Desconocido"
    function modeloChangeIsSafe() {
      return !('modelo' in request.resource.data.diff(resource.data).affectedKeys())
          || !isBadFallback(request.resource.data.modelo);
    }

    // ── Users collection ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Phones collection ─────────────────────────────────────────────────────
    match /phones/{phoneId} {
      // Allow public read of Stock/Apartado phones
      allow read: if isSignedIn() ||
                  resource.data.estado == 'En Stock (Disponible para Venta)' ||
                  resource.data.estado == 'Apartado';

      // Allow authenticated update only for reservation fields (SEC-1 fix)
      // Allow taller role to update workshop-specific fields (estado, statusHistory, reparaciones)
      // 2026-04-24: Added soft validation — legacy "Desconocida" marca tolerated on existing docs,
      // but BLOCKED from being introduced as a CHANGE. precioVenta must stay number type.
      allow update: if ((isAdmin() || isGerente()) ||
                        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reservation', 'updatedAt', 'estado']) && isValidReservationUpdate()) ||
                        (isTaller() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'statusHistory', 'reparaciones', 'updatedAt'])))
                    && marcaChangeIsSafe()
                    && modeloChangeIsSafe()
                    && precioTypeIsSafe();

      // 2026-04-24: Strict CREATE — reject new phones with "Desconocida" marca/modelo
      allow create: if isSignedIn()
                    && getUserData().role in ['admin', 'gerente', 'taller']
                    && hasValidPhoneCreate(request.resource.data);
      allow delete: if isAdmin();
    }

    // ── Batches collection ────────────────────────────────────────────────────
    match /batches/{batchId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }

    // ── Clients collection ────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isGerente();
      allow delete: if isAdmin();

      match /purchases/{purchaseId} {
        allow read: if isSignedIn();
        allow create: if isAdmin() || isGerente();
        allow update, delete: if isAdmin();
      }

      match /creditAdjustments/{adjId} {
        allow read: if isSignedIn();
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      match /debtAdjustments/{adjId} {
        allow read: if isSignedIn();
        allow create: if isAdmin() || isGerente();
        allow update, delete: if false;
      }

      match /debtPayments/{payId} {
        allow read: if isSignedIn();
        allow create: if isAdmin() || isGerente();
        allow update, delete: if false;
      }
    }

    // ── Accessories collection ────────────────────────────────────────────────
    match /accessories/{accessoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGerente();
    }

    // ── Device Definitions (Smart Learner) ────────────────────────────────────
    match /device_definitions/{tac} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGerente();
    }

    // ── Price Catalog (Brain 2.0) ─────────────────────────────────────────────
    // Read is open to all signed-in users (vendedor, comprador need price reference)
    // Write is restricted to admin/gerente to prevent data corruption
    match /price_catalog/{id} {
      allow read: if isSignedIn();
      allow write: if isAdminOrGerente();
    }

    // ── Pending Orders ────────────────────────────────────────────────────────
    // - Buyers can read their own orders (by clientId)
    // - Admin / Gerente can read all orders
    // - Any authenticated user can create (for B2B flow where order is created client-side)
    // - Clients can update their own order to mark payment method / pending_transfer
    // - Admin / Gerente can update any order (e.g. confirm transfer)
    // - Cloud Functions use admin SDK and bypass these rules entirely
    match /pendingOrders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.clientId == request.auth.uid ||
        isAdminOrGerente()
      );

      // Allow create if authenticated (B2B buyer creating order from catalog)
      allow create: if isSignedIn();

      // Buyer can ONLY update payment-related fields on their own order
      // Admin/Gerente can update any field
      allow update: if isSignedIn() && (
        (resource.data.clientId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'paymentMethod', 'transferDetails', 'updatedAt']) &&
         request.resource.data.status in ['pending_transfer', 'cancelled']
        ) ||
        isAdminOrGerente()
      );

      allow delete: if false;
    }

    // ── Shipments ─────────────────────────────────────────────────────────────
    match /shipments/{shipmentId} {
      // Buyers can read shipments where their uid matches clientId; admin/gerente can read all
      allow read: if isAdminOrGerente() ||
                  (isSignedIn() && resource.data.clientId == request.auth.uid);
      // Only admin/gerente can create or update shipments
      allow create, update: if isAdminOrGerente();
      allow delete: if false;
    }

    // ── Invoices (Sistema 4 — facturas de ventas) ─────────────────────────────
    match /invoices/{invoiceId} {
      allow read: if isAdminOrGerente();
      allow create: if isAdminOrGerente();
      allow update, delete: if isAdmin();
    }

    // ── Settings (invoice counter, etc.) ──────────────────────────────────────
    match /settings/{docId} {
      allow read: if isAdminOrGerente();
      allow write: if isAdminOrGerente();
    }

    // ── Reception Acts (Actas con firma digital) ───────────────────────────────
    match /receptionActs/{actId} {
      allow read: if isSignedIn();
      allow create: if isAdminOrGerente();
      allow update, delete: if isAdmin();
    }

    // ── Receiving Reports ─────────────────────────────────────────────────────
    match /receivingReports/{reportId} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOrGerente();
      allow delete: if isAdmin();
    }

    // ── Suppliers (proveedores mayoristas) ────────────────────────────────────
    match /suppliers/{supplierId} {
      allow read: if isAdminOrGerente();
      allow create, update: if isAdminOrGerente();
      allow delete: if isAdmin();
    }

    // ── Supplier Invoices (facturas importadas de proveedores) ─────────────────
    match /supplierInvoices/{invoiceId} {
      allow read: if isAdminOrGerente();
      allow create: if isAdminOrGerente();
      allow update: if isAdminOrGerente();
      allow delete: if isAdmin();
    }

    // ── Import Shipments (envíos USA → El Salvador) ───────────────────────────
    match /importShipments/{shipmentId} {
      allow read: if isAdminOrGerente();
      allow create, update: if isAdminOrGerente();
      allow delete: if isAdmin();
    }

    // ── Internal Codes (codigos de proveedor) ─────────────────────────────────
    // Lista compartida de supplier codes (WNY, KRA, RUB, etc). Doc ID = codigo.
    // Cualquier usuario logueado puede leer; admin/gerente puede crear nuevos
    // codigos desde el SupplierPicker. Update/delete solo admin.
    match /internal_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && getUserData().role in ['admin', 'gerente'];
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Deny all other access ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
